# ===== Claude API =====
# 在 https://console.anthropic.com 获取 API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# 使用的模型（默认 claude-opus-4-8，最强通用模型）
# 如需更快/更便宜可改为 claude-sonnet-4-6 或 claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-8

# 单条回复的最大 token 数
CLAUDE_MAX_TOKENS=1024

# 机器人的系统提示词（人设）
SYSTEM_PROMPT=你是一个友好、简洁的微信聊天助手。回答尽量口语化、贴近微信聊天风格，不要长篇大论。

# ===== Wechaty / 微信 =====
# 个人微信通过网页协议登录（wechaty-puppet-wechat），启动后扫码登录
WECHATY_PUPPET=wechaty-puppet-wechat

# ===== 机器人行为 =====
# 是否回复私聊消息（true/false）
REPLY_PRIVATE=true
# 群聊里是否只在被 @ 时才回复（true/false）
GROUP_REPLY_ON_MENTION_ONLY=true
# 每个会话保留的最大历史消息条数（控制上下文长度与成本）
MAX_HISTORY=20
