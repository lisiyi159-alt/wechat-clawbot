# ===== 选择大模型提供商 =====
# deepseek = 国内 DeepSeek（默认，推荐，国内注册/支付宝充值）
# claude   = Anthropic Claude（需要境外信用卡）
PROVIDER=deepseek

# ===== DeepSeek（PROVIDER=deepseek 时使用）=====
# 在 https://platform.deepseek.com 注册后，在「API Keys」创建密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# 模型：deepseek-chat（通用对话）或 deepseek-reasoner（推理更强、更慢）
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ===== Claude（PROVIDER=claude 时使用）=====
# 在 https://console.anthropic.com 获取 API Key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-opus-4-8

# ===== 通用设置 =====
# 单条回复的最大 token 数
MAX_TOKENS=1024
# 机器人的系统提示词（人设）
SYSTEM_PROMPT=你是一个友好、简洁的微信聊天助手。回答尽量口语化、贴近微信聊天风格，不要长篇大论。

# ===== Wechaty / 微信 =====
# 个人微信通过网页协议登录（wechaty-puppet-wechat），启动后扫码登录
WECHATY_PUPPET=wechaty-puppet-wechat

# ===== 机器人行为 =====
# 是否回复私聊消息（true/false）
REPLY_PRIVATE=true
# 群聊里是否只在被 @ 时才回复（true/false）
GROUP_REPLY_ON_MENTION_ONLY=true
# 每个会话保留的最大历史消息条数（控制上下文长度与成本）
MAX_HISTORY=20
