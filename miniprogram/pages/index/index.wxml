<view class="page">
  <view wx:if="{{loading}}" class="empty">加载中…</view>

  <view wx:elif="{{trips.length === 0}}" class="empty">
    <text>还没有旅行记录</text>
    <text class="sub">点右下角 ＋ 写下第一段旅程</text>
  </view>

  <view class="list" wx:else>
    <view
      class="card"
      wx:for="{{trips}}"
      wx:key="_id"
      bindtap="goDetail"
      data-id="{{item._id}}"
    >
      <image
        wx:if="{{item.cover}}"
        class="cover"
        src="{{item.cover}}"
        mode="aspectFill"
      />
      <view wx:else class="cover placeholder">🏞️</view>
      <view class="card-body">
        <view class="title">{{item.title}}</view>
        <view class="meta">
          <text wx:if="{{item.location}}">📍{{item.location}}</text>
          <text wx:if="{{item.date}}" class="date">{{item.date}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="fab" bindtap="goPublish">＋</view>
</view>
