.map-wrap {
  position: relative;
  width: 100%;
  height: 100vh;
}

.map {
  width: 100%;
  height: 100%;
}

.tip {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 80rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  text-align: center;
  color: #6b7280;
  font-size: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}
