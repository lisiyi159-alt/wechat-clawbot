<view class="form">
  <view class="field">
    <textarea
      class="textarea"
      placeholder="写下你的补充或感受…（会署上你的称呼）"
      value="{{text}}"
      bindinput="onInput"
      auto-height
      focus
    />
  </view>

  <view class="field">
    <view class="photo-grid">
      <view class="thumb" wx:for="{{photos}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" />
        <view class="del" data-index="{{index}}" bindtap="removeUploaded">×</view>
      </view>
      <view class="thumb" wx:for="{{localPhotos}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" />
        <view class="del" data-index="{{index}}" bindtap="removeLocal">×</view>
      </view>
      <view class="thumb add" bindtap="chooseImage">＋</view>
    </view>
  </view>

  <button
    class="submit btn-primary"
    bindtap="submit"
    loading="{{submitting}}"
    disabled="{{submitting}}"
  >
    保存
  </button>
</view>
