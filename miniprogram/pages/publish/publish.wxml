<view class="form">
  <view class="field">
    <text class="label">标题</text>
    <input
      class="input"
      placeholder="这次去了哪里？"
      value="{{title}}"
      data-field="title"
      bindinput="onInput"
    />
  </view>

  <view class="field">
    <text class="label">地点</text>
    <view class="loc-row">
      <input
        class="input loc-input"
        placeholder="城市 / 景点（可选）"
        value="{{location}}"
        data-field="location"
        bindinput="onInput"
      />
      <view class="loc-btn" bindtap="chooseLocation">📍地图选点</view>
    </view>
    <text class="hint" wx:if="{{latitude}}">已定位，会出现在「足迹」地图上</text>
  </view>

  <view class="field">
    <text class="label">日期</text>
    <picker mode="date" value="{{date}}" bindchange="onDateChange">
      <view class="input picker">{{date}}</view>
    </picker>
  </view>

  <view class="field">
    <text class="label">住宿酒店</text>
    <input
      class="input"
      placeholder="住在哪儿？（可选）"
      value="{{hotel}}"
      data-field="hotel"
      bindinput="onInput"
    />
  </view>

  <view class="field">
    <text class="label">出行交通</text>
    <picker
      mode="selector"
      range="{{transportOptions}}"
      value="{{transportIndex}}"
      bindchange="onTransportChange"
    >
      <view class="input picker">
        {{transportIndex >= 0 ? transportOptions[transportIndex] : '请选择'}}
      </view>
    </picker>
    <input
      wx:if="{{transport === '其他'}}"
      class="input"
      style="margin-top: 16rpx"
      placeholder="请填写出行方式"
      value="{{transportOther}}"
      data-field="transportOther"
      bindinput="onInput"
    />
  </view>

  <view class="field">
    <text class="label">游记（会署上你的称呼）</text>
    <textarea
      class="textarea"
      placeholder="写下这次旅行的故事和感受…"
      value="{{text}}"
      data-field="text"
      bindinput="onInput"
      auto-height
    />
  </view>

  <view class="field">
    <text class="label">照片</text>
    <view class="photo-grid">
      <view class="thumb" wx:for="{{photos}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" />
        <view class="del" data-index="{{index}}" bindtap="removeUploaded">×</view>
      </view>
      <view class="thumb" wx:for="{{localPhotos}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" />
        <view class="del" data-index="{{index}}" bindtap="removeLocal">×</view>
      </view>
      <view class="thumb add" bindtap="chooseImage">＋</view>
    </view>
  </view>

  <button
    class="submit btn-primary"
    bindtap="submit"
    loading="{{submitting}}"
    disabled="{{submitting}}"
  >
    保存
  </button>
</view>
