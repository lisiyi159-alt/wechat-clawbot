.form {
  padding: 24rpx 32rpx 80rpx;
}

.field {
  margin-bottom: 36rpx;
}

.label {
  display: block;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  color: #6b7280;
}

.input,
.picker {
  background: #fff;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
}

.textarea {
  width: 100%;
  box-sizing: border-box;
  min-height: 220rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.thumb {
  position: relative;
  width: 210rpx;
  height: 210rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #e5e7eb;
}

.thumb image {
  width: 100%;
  height: 100%;
}

.thumb.add {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: #9ca3af;
  border: 2rpx dashed #d1d5db;
  background: #fff;
}

.del {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 32rpx;
}

.submit {
  margin-top: 24rpx;
  font-size: 32rpx;
  padding: 12rpx 0;
}
