.detail {
  padding: 32rpx 32rpx 64rpx;
}

.head .title {
  font-size: 44rpx;
  font-weight: 700;
}

.head .meta {
  margin-top: 16rpx;
  color: #6b7280;
  font-size: 26rpx;
  display: flex;
  gap: 24rpx;
}

.content {
  margin-top: 32rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  color: #374151;
}

.photos {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.photo {
  width: 100%;
  border-radius: 16rpx;
  background: #e5e7eb;
}

.actions {
  margin-top: 48rpx;
  display: flex;
  gap: 24rpx;
}

.action {
  flex: 1;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.action.export {
  background: #10b981;
  color: #fff;
}

.action.edit {
  background: #f3f4f6;
  color: #374151;
}
