<view class="detail" wx:if="{{trip}}">
  <view class="head">
    <view class="title">{{trip.title}}</view>
    <view class="meta">
      <text wx:if="{{trip.location}}">📍 {{trip.location}}</text>
      <text wx:if="{{trip.date}}">🗓 {{trip.date}}</text>
    </view>
    <view class="meta" wx:if="{{trip.hotel || trip.transport}}">
      <text wx:if="{{trip.hotel}}">🏨 {{trip.hotel}}</text>
      <text wx:if="{{trip.transport}}">🚆 {{trip.transport === '其他' ? trip.transportOther : trip.transport}}</text>
    </view>
  </view>

  <!-- 多位家人的接力记录 -->
  <view class="entries">
    <view class="entry" wx:for="{{entries}}" wx:key="index" wx:for-item="entry">
      <view class="entry-head">
        <text class="who">{{entry.name}}{{entry.isFirst ? '：' : ' 补充：'}}</text>
        <view class="entry-ops" wx:if="{{entry.mine}}">
          <text class="op" data-index="{{entry.index}}" bindtap="editEntry">编辑</text>
          <text
            wx:if="{{!entry.isFirst}}"
            class="op del"
            data-index="{{entry.index}}"
            bindtap="deleteEntry"
          >删除</text>
        </view>
      </view>
      <view class="entry-text" wx:if="{{entry.text}}">{{entry.text}}</view>
      <view class="entry-photos" wx:if="{{entry.photoUrls.length}}">
        <image
          wx:for="{{entry.photoUrls}}"
          wx:for-item="p"
          wx:key="*this"
          class="photo"
          src="{{p}}"
          mode="widthFix"
          bindtap="preview"
          data-src="{{p}}"
          data-urls="{{entry.photoUrls}}"
        />
      </view>
    </view>
  </view>

  <view class="actions">
    <button class="action add" bindtap="addEntry">✍ 我也补充</button>
    <button class="action share" open-type="share">↗ 分享给家人</button>
    <button class="action export" bindtap="exportTrip">⬇ 导出留存</button>
  </view>
  <view class="actions" wx:if="{{canEdit}}">
    <button class="action edit" bindtap="editTrip">编辑旅行</button>
    <button class="action danger" bindtap="deleteTrip">删除整段</button>
  </view>
</view>

<view wx:elif="{{loading}}" class="empty">加载中…</view>
<view wx:else class="empty">没有找到这段旅行</view>
